{
  "name": "@whisperr/wizard",
  "version": "0.5.3",
  "description": "Generate a codebase-aware Whisperr intervention model and integrate its SDK and events in one command.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WhisperrAI/whisperr-wizard.git"
  },
  "homepage": "https://github.com/WhisperrAI/whisperr-wizard#readme",
  "license": "UNLICENSED",
  "private": false,
  "type": "module",
  "bin": {
    "whisperr": "dist/index.js"
  },
  "files": [
    "dist"
  ],
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "test": "node --import tsx --test test/*.test.ts",
    "prepublishOnly": "npm run build",
    "dev:local": "tsx src/index.ts"
  },
  "dependencies": {
    "@clack/prompts": "^1.5.1",
    "@openai/agents": "^0.13.5",
    "open": "^11.0.0",
    "picocolors": "^1.0.1",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/node": "^22.5.0",
    "tsup": "^8.2.4",
    "tsx": "^4.19.0",
    "typescript": "^5.6.2"
  }
}
